{
  "name": "@trippy/api",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/trpc/router.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src ./drizzle.config.ts",
    "dev": "bunx wrangler dev",
    "deploy": "bunx wrangler deploy --minify",
    "cf-typegen": "bunx wrangler types --env-interface CloudflareBindings",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth/auth.cli.ts --output src/auth/schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:push": "bunx wrangler d1 migrations apply trippy-db --local"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@better-auth/expo": "^1.6.9",
    "@trippy/core": "workspace:*",
    "@trpc/server": "^11.17.0",
    "ai": "^6.0.169",
    "better-auth": "^1.4.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@trippy/tsconfig": "workspace:*",
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.3",
    "wrangler": "^4.92.0"
  }
}