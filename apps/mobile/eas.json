{
	"cli": {
		"version": ">= 18.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"ios": {
				"simulator": true
			},
			"env": {
				"VARIANT": "development"
			}
		},
		"development-device": {
			"extends": "development",
			"ios": {
				"simulator": false
			},
			"env": {
				"VARIANT": "development"
			}
		},
		"production": {
			"autoIncrement": true,
			"env": {
				"VARIANT": "production"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
